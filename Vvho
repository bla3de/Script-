if GameName == "UNSUPPORTED" then
    warn("Exodus Hub: Unsupported Game")
    task.wait(2)
    FadeOut()
else
    -- PROGRESS BAR DOWNLOAD LOGIC
    local function fillBar(percent, duration)
        local t = TweenService:Create(Fill, TweenInfo.new(duration, Enum.EasingStyle.Sine), {Size = UDim2.new(percent, 0, 1, 0)})
        t:Play()
        t.Completed:Wait()
    end

    -- Stage 1: Load to 40%
    fillBar(0.4, 0.6)
    task.wait(0.4) -- First Stop
    
    -- Stage 2: Crawl to 85%
    fillBar(0.85, 1.2)
    task.wait(0.6) -- Second Stop
    
    -- Stage 3: Complete
    fillBar(1, 0.4)
    task.wait(0.5)

    print("ZenX Hub: Loaded for " .. GameName)
    FadeOut()
    
