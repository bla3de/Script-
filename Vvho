-- ANIMATION: FADE IN
local function FadeIn()
    local info = TweenInfo.new(0.8, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
    TweenService:Create(MainFrame, info, {Position = UDim2.new(0.5, -140, 0.5, -150), BackgroundTransparency = bgTransparency}):Play()
    TweenService:Create(UIStroke, info, {Transparency = 0}):Play()
    TweenService:Create(Logo, info, {ImageTransparency = 0}):Play()
    TweenService:Create(GameStatus, info, {TextTransparency = 0}):Play()
    TweenService:Create(GameLabel, info, {TextTransparency = 0}):Play()
    TweenService:Create(Credits, info, {TextTransparency = 0}):Play()
    -- Fade in bar
    TweenService:Create(BarBG, info, {BackgroundTransparency = 0}):Play()
    TweenService:Create(BarStroke, info, {Transparency = 0}):Play()
    TweenService:Create(Fill, info, {BackgroundTransparency = 0}):Play()
end

-- ANIMATION: FADE OUT
local function FadeOut()
    local info = TweenInfo.new(0.6, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
    TweenService:Create(MainFrame, info, {Position = UDim2.new(0.5, -140, 0.6, -150), BackgroundTransparency = 1}):Play()
    TweenService:Create(UIStroke, info, {Transparency = 1}):Play()
    TweenService:Create(Logo, info, {ImageTransparency = 1}):Play()
    TweenService:Create(GameStatus, info, {TextTransparency = 1}):Play()
    TweenService:Create(GameLabel, info, {TextTransparency = 1}):Play()
    TweenService:Create(Credits, info, {TextTransparency = 1}):Play()
    -- Fade out bar
    TweenService:Create(BarBG, info, {BackgroundTransparency = 1}):Play()
    TweenService:Create(BarStroke, info, {Transparency = 1}):Play()
    TweenService:Create(Fill, info, {BackgroundTransparency = 1}):Play()
    
    task.wait(0.6)
    ScreenGui:Destroy()
end

-- Start Logic
